NODE_ENV=development
API_PORT=3000

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/flavohub?sslmode=require

# JWT secrets — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace_with_random_hex_64_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=replace_with_random_hex_64_chars
JWT_REFRESH_TTL=7d

# Super-admin seed credentials
SUPER_ADMIN_EMAIL=admin@flavohub.local
SUPER_ADMIN_PASSWORD=ChangeMe@12345

# Public URL of this API (used by the keepalive ping in production)
APP_URL=https://flavohub-api.onrender.com

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=https://flavohub-admin.vercel.app,https://flavohub-restaurant.vercel.app
